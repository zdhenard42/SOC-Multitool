{
    "manifest_version": 3,
    "name": "SOC Multitool",
    "version": "1.0",
    "description": "My SOC Multitool, used this project to keep my mind off of hunger during no-lunch Wednesdays.",
    "icons": {
        "128": "icon128.png",
        "48": "icon48.png",
        "16": "icon16.png"
    },
	"background": {
        "service_worker": "eventPage.js"
    },
    "permissions": [
        "tabs",
        "contextMenus",
		"activeTab"
    ]
}